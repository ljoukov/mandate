    "@types/node": "^26.0.1",
    "svelte": "^5.34.0",
    "svelte-check": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "@lucide/svelte": "^1.21.0",
    "@solana/actions": "^1.6.6"
  }
